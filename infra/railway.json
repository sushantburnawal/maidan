{
  "$schema": "https://railway.app/railway.schema.json",
  "services": {
    "api": {
      "rootDirectory": ".",
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "infra/api.Dockerfile"
      },
      "deploy": {
        "startCommand": "node apps/api/dist/src/main.js",
        "healthcheckPath": "/health/ready",
        "healthcheckTimeout": 100,
        "restartPolicyType": "ON_FAILURE"
      }
    },
    "ai": {
      "rootDirectory": ".",
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "infra/ai.Dockerfile"
      },
      "deploy": {
        "startCommand": "uvicorn maidan_ai.main:app --host 0.0.0.0 --port $PORT",
        "healthcheckPath": "/health/ready",
        "healthcheckTimeout": 100,
        "restartPolicyType": "ON_FAILURE"
      }
    }
  },
  "plugins": {
    "postgres": {
      "type": "postgresql",
      "env": {
        "DATABASE_URL": "${{Postgres.DATABASE_URL}}"
      }
    },
    "redis": {
      "type": "redis",
      "env": {
        "REDIS_URL": "${{Redis.REDIS_URL}}"
      }
    }
  }
}
