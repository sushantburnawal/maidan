# Copy to .env for local development. Keep real secrets out of git.

# General
COMMIT_SHA=local
LOG_LEVEL=debug

# API service
NODE_ENV=development
API_PORT=3000
HOST=0.0.0.0
PORT=3000
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# AI service
PYTHON_ENV=development
AI_PORT=8000
AI_WORKER_CONCURRENCY=2

# Database / Supabase Postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=54322
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_SSL=false
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me
SUPABASE_JWT_SECRET=replace-me

# Redis / queues / streams
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
BULLMQ_PREFIX=maidan
OUTBOX_RELAY_ENABLED=true
OUTBOX_RELAY_INTERVAL_MS=5000
OUTBOX_RELAY_BATCH_SIZE=50

# Auth / JWT
JWT_ACCESS_SECRET=replace-me-access-secret
JWT_REFRESH_SECRET=replace-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# MSG91 OTP/SMS
MSG91_API_KEY=replace-me
MSG91_AUTH_KEY=replace-me
MSG91_SENDER_ID=MAIDAN
MSG91_OTP_TEMPLATE_ID=replace-me
MSG91_OTP_EXPIRY_MINUTES=10

# PhonePe split-settlement payments
PHONEPE_BASE_URL=https://api-preprod.phonepe.com/apis/pg-sandbox
PHONEPE_AUTH_URL=https://api-preprod.phonepe.com/apis/pg-sandbox/v1/oauth/token
PHONEPE_CLIENT_ID=replace-me
PHONEPE_CLIENT_VERSION=1
PHONEPE_CLIENT_SECRET=replace-me
PHONEPE_MERCHANT_ID=replace-me
PHONEPE_SALT_KEY=replace-me
PHONEPE_SALT_INDEX=1
PHONEPE_CALLBACK_URL=http://localhost:3000/payments/webhook
PHONEPE_REDIRECT_URL=http://localhost:3000/payments/return
PHONEPE_WEBHOOK_USERNAME=replace-me
PHONEPE_WEBHOOK_PASSWORD=replace-me
PHONEPE_WEBHOOK_SECRET=replace-me
PHONEPE_SPLIT_SETTLEMENT_ENABLED=true
PLATFORM_FEE_PCT=15
PLATFORM_FEE_FLOOR_INR=0
MAIDAN_PHONEPE_MERCHANT_REF=maidan-phonepe-merchant

# Firebase Cloud Messaging
FCM_PROJECT_ID=replace-me
FCM_CLIENT_EMAIL=replace-me
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-me\n-----END PRIVATE KEY-----\n"
FCM_WEB_PUSH_PUBLIC_KEY=replace-me

# Anthropic LLMs
ANTHROPIC_API_KEY=replace-me
ANTHROPIC_HAIKU_MODEL=claude-3-5-haiku-latest
ANTHROPIC_SONNET_MODEL=claude-sonnet-4-20250514

# Self-hosted embeddings
EMBEDDINGS_BASE_URL=http://localhost:8080
EMBEDDINGS_MODEL=maidan-local-embeddings
EMBEDDINGS_DIMENSIONS=768
