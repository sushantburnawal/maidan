# Copy to .env for local development. Keep real secrets out of git.

# General
COMMIT_SHA=local
LOG_LEVEL=debug
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW_SECONDS=60
RATE_LIMIT_WRITE_MAX=60
RATE_LIMIT_WRITE_WINDOW_SECONDS=60

# API service
NODE_ENV=development
API_PORT=3000
HOST=0.0.0.0
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Web service
WEB_PORT=5173
VITE_API_BASE_URL=http://localhost:3000

# AI service
PYTHON_ENV=development
AI_PORT=8000
AI_WORKER_CONCURRENCY=2
AI_BASE_URL=http://localhost:8000
AI_INTERNAL_TOKEN=replace-me-internal-token
API_HEALTHCHECK_AI_DISABLED=false
AI_PROVIDER=openrouter

# Database / Supabase Postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=54322
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_SSL=false
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me
SUPABASE_JWT_SECRET=replace-me

# Redis / queues / streams
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
BULLMQ_PREFIX=maidan
STREAM_DOMAIN_EVENTS=maidan.events
QUEUE_MODERATION=maidan.moderation
QUEUE_EMBEDDINGS=maidan.embeddings
QUEUE_NOTIFICATIONS=maidan.notifications
OUTBOX_RELAY_ENABLED=true
OUTBOX_RELAY_INTERVAL_MS=5000
OUTBOX_RELAY_BATCH_SIZE=50
NOTIFICATIONS_WORKER_DISABLED=false
REALTIME_REDIS_PRESENCE_DISABLED=false

# Auth / JWT
JWT_ACCESS_SECRET=replace-me-access-secret
JWT_REFRESH_SECRET=replace-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# MSG91 OTP/SMS
MSG91_API_KEY=replace-me
MSG91_AUTH_KEY=replace-me
MSG91_SENDER_ID=MAIDAN
MSG91_OTP_TEMPLATE_ID=replace-me
MSG91_OTP_EXPIRY_MINUTES=10

# PhonePe split-settlement payments
PHONEPE_BASE_URL=https://api-preprod.phonepe.com/apis/pg-sandbox
PHONEPE_AUTH_URL=https://api-preprod.phonepe.com/apis/pg-sandbox/v1/oauth/token
PHONEPE_CLIENT_ID=replace-me
PHONEPE_CLIENT_VERSION=1
PHONEPE_CLIENT_SECRET=replace-me
PHONEPE_MERCHANT_ID=replace-me
PHONEPE_SALT_KEY=replace-me
PHONEPE_SALT_INDEX=1
PHONEPE_CALLBACK_URL=http://localhost:3000/payments/webhook
PHONEPE_REDIRECT_URL=http://localhost:3000/payments/return
PHONEPE_WEBHOOK_USERNAME=replace-me
PHONEPE_WEBHOOK_PASSWORD=replace-me
PHONEPE_WEBHOOK_SECRET=replace-me
PHONEPE_SPLIT_SETTLEMENT_ENABLED=true
PLATFORM_FEE_PCT=15
PLATFORM_FEE_FLOOR_INR=0
MAIDAN_PHONEPE_MERCHANT_REF=maidan-phonepe-merchant

# Firebase Cloud Messaging
FCM_PROJECT_ID=replace-me
FCM_CLIENT_EMAIL=replace-me
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-me\n-----END PRIVATE KEY-----\n"
FCM_WEB_PUSH_PUBLIC_KEY=replace-me

# LLM providers
OPENROUTER_API_KEY=replace-me-openrouter-key
OPENROUTER_MODEL_CONVERSATIONAL=google/gemma-4-31b-it:free
OPENROUTER_MODEL_MODERATION=google/gemma-4-31b-it:free
# Alternative conversational/moderation candidate:
# OPENROUTER_MODEL_CONVERSATIONAL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
# OPENROUTER_MODEL_MODERATION=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
ANTHROPIC_API_KEY=replace-me
ANTHROPIC_HAIKU_MODEL=claude-3-5-haiku-latest
ANTHROPIC_SONNET_MODEL=claude-sonnet-4-20250514
ANTHROPIC_HAIKU_INPUT_USD_PER_MTOK=1
ANTHROPIC_HAIKU_OUTPUT_USD_PER_MTOK=5
ANTHROPIC_HAIKU_CACHE_WRITE_USD_PER_MTOK=1.25
ANTHROPIC_HAIKU_CACHE_READ_USD_PER_MTOK=0.10
ANTHROPIC_SONNET_INPUT_USD_PER_MTOK=3
ANTHROPIC_SONNET_OUTPUT_USD_PER_MTOK=15
ANTHROPIC_SONNET_CACHE_WRITE_USD_PER_MTOK=3.75
ANTHROPIC_SONNET_CACHE_READ_USD_PER_MTOK=0.30

# Self-hosted embeddings
EMBEDDINGS_MODEL=sentence-transformers/all-mpnet-base-v2
EMBEDDINGS_DIMENSIONS=768
EMBEDDINGS_DEVICE=cpu
EMBEDDINGS_BATCH_SIZE=16
EMBEDDINGS_WORKER_DISABLED=false
EMBEDDINGS_QUEUE_BLOCK_SECONDS=5
MODERATION_WORKER_DISABLED=false
MODERATION_QUEUE_BLOCK_SECONDS=5
MODERATION_BATCH_SIZE=8
MODERATION_BATCH_WINDOW_SECONDS=0.25
DEMAND_SENSING_WORKER_DISABLED=false
DEMAND_SENSING_WINDOW_DAYS=14
DEMAND_SENSING_SUPPLY_HORIZON_DAYS=30
DEMAND_SENSING_BATCH_SIZE=12
DEMAND_SENSING_STRONG_THRESHOLD=0.7
DEMAND_SENSING_THIN_OPEN_SLOT_THRESHOLD=0
DEMAND_SENSING_INITIAL_DELAY_SECONDS=60
DEMAND_SENSING_INTERVAL_SECONDS=86400
MATCHMAKER_WORKER_DISABLED=false
MATCHMAKER_BATCH_SIZE=100
MATCHMAKER_INITIAL_DELAY_SECONDS=60
MATCHMAKER_INTERVAL_SECONDS=86400
