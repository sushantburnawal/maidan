{
  "name": "@maidan/shared",
  "version": "0.0.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./contracts/events.schema.json": "./contracts/events.schema.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/generate-events-schema.mjs",
