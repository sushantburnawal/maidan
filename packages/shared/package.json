    "test": "jest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "zod-to-json-schema": "^3.24.1"
  }
